{
  "base_url": {
    "description": "教务基础地址，例如 http://jw.nnnu.edu.cn",
    "type": "string",
    "default": "http://jw.nnnu.edu.cn",
    "hint": "必填"
  },
  "account": {
    "description": "教务账号",
    "type": "string",
    "default": "",
    "hint": "必填"
  },
  "password": {
    "description": "教务密码",
    "type": "string",
    "default": "",
    "hint": "必填"
  },
  "max_login_attempts": {
    "description": "验证码最大重试次数",
    "type": "int",
    "default": 8
  },
  "request_timeout": {
    "description": "HTTP 超时(秒)",
    "type": "float",
    "default": 20.0
  },
  "enable_daily_push": {
    "description": "是否启用提醒推送循环",
    "type": "bool",
    "default": true
  },
  "enable_file_log": {
    "description": "是否启用文件日志",
    "type": "bool",
    "default": true
  },
  "log_file_path": {
    "description": "日志文件路径（相对路径相对插件目录）",
    "type": "string",
    "default": "runtime.log"
  },
  "timezone": {
    "description": "时区",
    "type": "string",
    "default": "Asia/Shanghai"
  },
  "push_prefix": {
    "description": "推送消息前缀",
    "type": "string",
    "default": "【上课提醒】"
  },
  "session_remind_before_minutes": {
    "description": "上午/下午课程提前提醒分钟",
    "type": "int",
    "default": 60
  },
  "morning_period_max": {
    "description": "上午节次上限（<= 该节次算上午）",
    "type": "int",
    "default": 5
  },
  "afternoon_period_max": {
    "description": "下午节次上限（> morning 且 <= 该值算下午）",
    "type": "int",
    "default": 9
  },
  "course_cache_seconds": {
    "description": "课表缓存秒数",
    "type": "int",
    "default": 900
  },
  "require_week_filter_for_push": {
    "description": "推送前要求按教学周过滤（无法确定周次则跳过推送）",
    "type": "bool",
    "default": true
  },
  "period_start_time_map": {
    "description": "节次开始时间映射（可选，建议留空使用内置武鸣作息）",
    "type": "string",
    "default": ""
  },
  "current_week": {
    "description": "当前教学周（可选，优先级最高）",
    "type": "int",
    "default": 0
  },
  "term_start_date": {
    "description": "学期起始日期（可选，格式 YYYY-MM-DD）",
    "type": "string",
    "default": ""
  },
  "term_start_week": {
    "description": "起始日期对应的教学周",
    "type": "int",
    "default": 1
  }
}
